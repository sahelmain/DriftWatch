# Set to the full backend URL when the frontend talks directly to the API.
# The public demo uses Koyeb + Vercel with a direct API URL.
VITE_API_URL=https://driftwatch-demo-api.koyeb.app/api

# Optional demo-only auto-login for local development or preview environments.
# Keep this disabled in production.
# VITE_ENABLE_DEMO_AUTO_LOGIN=true
# VITE_DEMO_EMAIL=smoke@test.io
# VITE_DEMO_PASSWORD=smoke1234
# VITE_DEMO_ORG=Smoke Test Org

# Sentry (optional — errors are silently skipped if unset)
# VITE_SENTRY_DSN=https://your-dsn@o123.ingest.us.sentry.io/456
