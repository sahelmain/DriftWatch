# Required in production — set via platform env vars (Koyeb, Render, Railway, etc.)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/driftwatch
SECRET_KEY=generate-a-random-64-char-string
AUTO_CREATE_SCHEMA=true
ENABLE_INLINE_SCHEDULER=false
ENABLE_INLINE_RUNS=true
PUBLIC_DEMO_MODE=true
DEMO_ALLOWED_MODELS_JSON=["gemini-2.5-flash-lite"]
DEMO_MAX_TESTS_PER_SUITE=3
DEMO_MAX_RUNS_PER_USER_PER_DAY=10

# Allowed frontend origins (JSON list)
CORS_ORIGINS=["http://localhost:5173","https://driftwatch-eight.vercel.app"]

# Sentry (optional — errors are silently skipped if unset)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.5

# Optional provider integrations
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_RPM=10
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL_PRICING_JSON={}

# Optional worker/full-stack settings
REDIS_URL=redis://host:6379/0

# Optional integrations
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@driftwatch.io
