# Required in production — set via platform env vars (Render, Railway, etc.)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/driftwatch
REDIS_URL=redis://host:6379/0
SECRET_KEY=generate-a-random-64-char-string
AUTO_CREATE_SCHEMA=false
ENABLE_INLINE_SCHEDULER=false

# Allowed frontend origins (JSON list)
CORS_ORIGINS=["https://driftwatch.vercel.app"]

# Sentry (optional — errors are silently skipped if unset)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.5

# Optional integrations
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@driftwatch.io
